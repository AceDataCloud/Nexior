# npm install used to fail on this repo because @capacitor/app@8 / @capacitor/browser@8
# declare a peer dep on @capacitor/core@^8, but the project pins @capacitor/core@^7
# (because @capacitor/android@7 + @capacitor/ios@7 are still on the 7.x line and
# moving to 8.x has not been verified for our native shells yet).
#
# Yarn 1 tolerated the mismatch with a warning. npm 7+ rejects it by default.
# This single flag restores yarn-1 behavior so installs work everywhere — local,
# CI, Docker, Cloudflare Pages — without needing a `--legacy-peer-deps` flag at
# every call site.
legacy-peer-deps=true
