# ---- Gzip compression ----
gzip on;
gzip_vary on;
gzip_proxied any;
gzip_comp_level 5;
gzip_min_length 256;
gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    image/svg+xml
    font/woff2;

# Prerender log format
log_format prerender_main '$remote_addr - $remote_user [$time_local] '
    '"$request" $status $body_bytes_sent '
    '"$http_referer" "$http_user_agent" '
    'rt=$request_time '
    'hit="$sent_http_x_prerender_hit" '
    'fallback="$sent_http_x_prerender_fallback" '
    'do_prerender="$do_prerender"';

access_log /dev/stdout prerender_main;

# Map 1: detect search engine / social crawlers
map $http_user_agent $prerender_ua {
    default                      0;
    "~*googlebot"                1;
    "~*bingbot"                  1;
    "~*yandex"                   1;
    "~*baiduspider"              1;
    "~*duckduckbot"              1;
    "~*facebookexternalhit"      1;
    "~*twitterbot"               1;
    "~*rogerbot"                 1;
    "~*linkedinbot"              1;
    "~*embedly"                  1;
    "~*showyoubot"               1;
    "~*outbrain"                 1;
    "~*pinterest"                1;
    "~*slackbot"                 1;
    "~*vkShare"                  1;
    "~*W3C_Validator"            1;
    "~*whatsapp"                 1;
    "~*applebot"                 1;
    "~*Sogou"                    1;
    "~*360Spider"                1;
    "~*Bytespider"               1;
    "~*PetalBot"                 1;
}

# Map 2: SEO whitelist – only public pages should be prerendered
map $uri $prerender_uri {
    default                                          0;
    "~^/$"                                           1;
    "~^/(chatgpt|claude|gemini|grok|deepseek)/?$"    1;
    "~^/(midjourney|flux|qrart|headshots|nanobanana|seedream)/?$" 1;
    "~^/(luma|sora|veo|pika|kling|pixverse|hailuo|seedance)/?$"  1;
    "~^/(suno)/?$"                                   1;
    "~^/(distribution)/?$"                           1;
}

# Map 3: skip static assets
map $uri $prerender_is_asset {
    default 0;
    "~*\.(js|css|xml|less|png|jpg|jpeg|gif|pdf|txt|ico|rss|zip|mp3|rar|exe|wmv|avi|ppt|mpg|mpeg|tif|wav|mov|svg|eot|ttf|woff|woff2|webp|avif|map|json)$" 1;
}

# Map 4: skip operational / authenticated paths
map $uri $prerender_is_op {
    default 0;
    "~^/(api|auth|console|static|assets|profile|site)/" 1;
}

# Final combined prerender decision (all four must be true for prerender)
map "$prerender_ua:$prerender_uri:$prerender_is_asset:$prerender_is_op" $do_prerender {
    "1:1:0:0" 1;
    default   0;
}

server {
    listen 80;
    server_name localhost;

    resolver ${NGINX_RESOLVER} valid=30s;

    # ---- Set shared proxy headers once here ----
    proxy_http_version 1.1;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host $host;

    client_max_body_size 20m;

    location /api/v1/ {
        proxy_pass https://platform.acedata.cloud;
    }

    # ---- Static assets: hash-based filenames → immutable caching ----
    location /assets/ {
        root /usr/share/nginx/html;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        access_log off;
    }

    # ---- Fonts: long-lived caching ----
    location /fonts/ {
        root /usr/share/nginx/html;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        access_log off;
    }

    # Prerender for search engine crawlers via prerender.io hosted service.
    location / {
        root   /usr/share/nginx/html;
        index  index.html index.htm;

        if ($do_prerender = 1) {
            rewrite (.*) /prerenderio last;
        }

        try_files $uri $uri/ @spa_fallback;
    }

    # SPA fallback: serve index.html for any unmatched route (client-side routing).
    location @spa_fallback {
        root /usr/share/nginx/html;
        add_header Cache-Control "private, no-store, no-cache, must-revalidate" always;
        add_header Pragma "no-cache" always;
        try_files /index.html =500;
    }

    # Explicit location for /index.html: prevent CDN from caching the SPA shell.
    location = /index.html {
        root /usr/share/nginx/html;
        add_header Cache-Control "private, no-store, no-cache, must-revalidate" always;
        add_header Pragma "no-cache" always;
    }

    location /prerenderio {
        internal;

        proxy_intercept_errors on;
        error_page 401 403 404 429 500 502 503 504 = @prerender_fallback;
        proxy_connect_timeout 3s;
        proxy_read_timeout 10s;
        proxy_send_timeout 10s;

        proxy_set_header X-Prerender-Token "${PRERENDER_TOKEN}";
        proxy_set_header X-Prerender-Int-Type "Reverse Proxy";
        proxy_set_header Accept-Encoding "";
        add_header X-Prerender-Hit "1" always;
        add_header Cache-Control "private, no-store" always;

        rewrite ^/prerenderio(.*)$ /$scheme://$host$1 break;
        proxy_pass ${PRERENDER_URL};
    }

    location @prerender_fallback {
        root /usr/share/nginx/html;
        add_header X-Prerender-Fallback "1" always;
        try_files /index.html =404;
    }

    error_page 500 502 503 504 /50x.html;

    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
